{
  "expo": {
    "name": "MoshPit",
    "slug": "MoshPit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "moshpit",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_PROJECT_ID"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moshpit.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "MoshPit needs access to your photo library to select photos for collages.",
        "NSPhotoLibraryAddUsageDescription": "MoshPit needs permission to save collages to your photo library.",
        "NSCameraUsageDescription": "MoshPit needs camera access to take photos for your collages."
      }
    },
    "android": {
      "package": "com.moshpit.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ],
      "expo-status-bar",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow MoshPit to save collages to your photo library.",
          "savePhotosPermission": "Allow MoshPit to save collages to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MoshPit to access your photos for creating collages.",
          "cameraPermission": "Allow MoshPit to take photos for your collages."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
